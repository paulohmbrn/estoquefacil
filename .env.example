# ============================================================
# Estoque Fácil — variáveis de ambiente (copie para .env)
# ============================================================

NODE_ENV=development

# ---- Banco de dados (postgres-estoque do docker-compose.dev) ----
DATABASE_URL=postgresql://estoque:estoque_dev@localhost:5532/estoque_facil?schema=public

# ---- Redis (redis-estoque do docker-compose.dev) ----
REDIS_URL=redis://localhost:6479

# ---- ZmartBI / Teknisa ----
ZMARTBI_BASE_URL=https://api-zmartbi.teknisa.com
ZMARTBI_TOKEN=NjllZTI0MTVlMzc3ZjEyNWJhMjUxMmQ5XzExNDg=

# ---- Auth.js (next-auth v5) ----
# gere com: openssl rand -base64 32
AUTH_SECRET=please-generate-with-openssl-rand-base64-32
# Em produção: https://estoque.reismagos.com.br
AUTH_URL=http://localhost:3000

# Whitelist de domínio para login Google
ALLOWED_EMAIL_DOMAIN=reismagos.com.br

# Google OAuth — criar OAuth 2.0 Client ID em https://console.cloud.google.com
# Authorized JavaScript origins:
#   https://estoque.reismagos.com.br
#   http://localhost:3000
# Authorized redirect URIs:
#   https://estoque.reismagos.com.br/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- API (apps/api) ----
API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
