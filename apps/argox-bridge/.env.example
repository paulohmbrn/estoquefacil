# ===== Impressora térmica (obrigatório) =====
# Modo de saída: "tcp" (rede) ou "usb" (Windows + fila local compartilhada).
PRINTER_MODE=tcp

# Quando PRINTER_MODE=tcp:
PRINTER_HOST=192.168.1.50
PRINTER_PORT=9100

# Quando PRINTER_MODE=usb (somente Windows):
# Nome do COMPARTILHAMENTO da fila (Painel de Controle → Impressora →
# Propriedades → Compartilhamento → "Nome do compartilhamento").
# A fila deve usar o driver "Generic / Text Only" pra raw ZPL passar.
PRINTER_NAME=

# ===== HTTP local (modo legado) =====
LISTEN_PORT=9101
ALLOWED_ORIGIN=https://estoque.reismagos.com.br

# ===== WebSocket persistente com cloud (recomendado) =====
# Gere o BRIDGE_TOKEN no painel: Cadastros → Lojas → [sua loja] → Impressora Argox
BRIDGE_TOKEN=
SERVER_WS_URL=wss://estoque.reismagos.com.br/argox/agent
